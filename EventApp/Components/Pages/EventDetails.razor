@page "/events/{id:int}"

@using EventApp


<h3>
    Event Details
</h3>


@if (eventItem == null)
{
    <p>
        Event not found
    </p>
}
else
{
    <h2>
        @eventItem.Name
    </h2>


    <p>
        Date:
        @eventItem.Date
    </p>


    <p>
        Location:
        @eventItem.Location
    </p>


    <p>
        @eventItem.Description
    </p>


    <a class="btn btn-success"
       href="/register/@eventItem.Id">

        Register

    </a>
}



@code {

    [Parameter]
    public int id { get; set; }


    private EventModel? eventItem;


    protected override void OnInitialized()
    {
        eventItem =
            EventData.Events
            .FirstOrDefault(e => e.Id == id);
    }

}